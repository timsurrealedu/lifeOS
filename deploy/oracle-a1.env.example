# Copy this to `oracle-a1.env` and fill in the values.
# Every value is discoverable with the OCI CLI commands in deploy/oracle-a1-retry.md.

# Root compartment = your tenancy OCID (the grabber launches into the root compartment).
COMPARTMENT_OCID="ocid1.tenancy.oc1..xxxxxxxx"

# The PUBLIC subnet OCID of the VCN you already created in the Oracle console.
SUBNET_OCID="ocid1.subnet.oc1.<region>.xxxxxxxx"

# An **aarch64** Ubuntu image OCID (ARM — required for A1.Flex). Discovery cmd in the guide.
IMAGE_OCID="ocid1.image.oc1.<region>.xxxxxxxx"

# Availability domain name(s), space-separated. Most regions near you (e.g. Singapore) have just one.
# Example value looks like:  "abCD:AP-SINGAPORE-1-AD-1"
AVAILABILITY_DOMAINS="abCD:AP-SINGAPORE-1-AD-1"

# Public key that gets injected into the new A1 so you can SSH in. Generate one on the GCP box:
#   ssh-keygen -t ed25519 -f ~/.ssh/oracle_a1 -N ""
# then point this at the .pub file. Keep the matching private key (~/.ssh/oracle_a1) safe.
SSH_PUBKEY_PATH="/home/YOURUSER/.ssh/oracle_a1.pub"

# Shape sizing — 2 OCPU / 12 GB is within the free 4 OCPU / 24 GB ceiling. Lower OCPUS/MEM_GB
# (e.g. 1 / 6) can land slightly more often when capacity is tight.
SHAPE="VM.Standard.A1.Flex"
OCPUS="2"
MEM_GB="12"
DISPLAY_NAME="lifeos-a1"

# Pacing. 180s between tries is safe against Oracle's rate limit; bump RATE_SLEEP if you still get 429s.
INTERVAL_SECONDS="180"
RATE_SLEEP_SECONDS="600"

# Running on an OCI VM? Use instance-principal auth (no API keys). Needs a dynamic group + policy
# (see oracle-a1-retry.md). Leave blank to use a normal ~/.oci/config API key instead.
OCI_AUTH="instance_principal"

# Optional: point at the synced vault so a 🎉 note lands in your lifeOS inbox when it catches the A1.
VAULT_DIR="/home/ubuntu/Obsidian Vault"
